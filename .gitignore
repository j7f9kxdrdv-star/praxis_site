# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local-only tooling state
.claude/worktrees/

# Reference textbook corpus — large local cache, not committed
# (~350MB PDFs + ~33MB text). Used only for content verification on
# the local machine. License terms (LibreTexts CC BY-NC-SA) also
# preclude redistribution in a commercial repository.
reference-textbooks/
